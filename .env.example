# Database Configuration
# Defaults to SQLite if not provided: sqlite:///./sira_prototype.db
# For PostgreSQL via docker-compose use: postgresql://sira_user:sira_pass@db:5432/sira_db
DATABASE_URL=postgresql://sira_user:sira_pass@localhost:5432/sira_db

# LLM API Configuration
# Put your OpenAI-compatible API key here (e.g., OpenAI or Qwen API key)
OPENAI_API_KEY=your_api_key_here

# For Qwen API, set the base URL (e.g. DashScope or equivalent compatible endpoint)
# Standard OpenAI: https://api.openai.com/v1
# DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model names:
# OpenAI: gpt-4o-mini, gpt-3.5-turbo
# Qwen: qwen-plus, qwen-turbo
OPENAI_MODEL_NAME=qwen-plus

# Server configuration
PORT=8000
HOST=0.0.0.0
